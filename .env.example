PORT=3000

# ServiceDesk Plus MSP (On-Premise)
SERVICEDESK_BASE_URL=http://your-sdp-server:8080
SERVICEDESK_API_KEY=your_technician_key_here

# Zoho OpManager
OPMANAGER_BASE_URL=http://your-opmanager-server:8060
OPMANAGER_API_KEY=your_opmanager_api_key_here

# Set to "true" to skip external API calls (for local testing)
DRY_RUN=true

# Correlation time window in minutes
CORRELATION_WINDOW_MINUTES=5

DATABASE_URL="file:./dev.db"
AUTH_TOKEN=